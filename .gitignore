# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.venv/
venv/
env/
build/
dist/
*.egg-info/

# API keys / secrets (belt and suspenders)
.env
.env.*
*.key
**/key
**/api_key
**/api-key

# SQLite (content-addressable; always regenerable)
*.db
*.db-wal
*.db-shm

# SWIFTbot runtime artefacts (regenerable from code + registered target families).
# We keep the top-level sweep_runs/ dir tracked so its driver .py scripts and
# summary .txt files commit; large .db and per-run logs/ stay ignored.
hank/sweep_runs/*.db
hank/sweep_runs/*.db-wal
hank/sweep_runs/*.db-shm
hank/sweep_runs/logs/
hank/sweep_runs/*.stdout
hank/sweep_runs/*.stderr
hank/literature/paper_extracted/
hank/swiftbot/.pi_cache/

# Claude Code agent state (per-user)
hank/.claude/

# LaTeX build artefacts (paper/ keeps .tex, .bib, .pdf; regenerable log/aux)
hank/paper/*.aux
hank/paper/*.log
hank/paper/*.bbl
hank/paper/*.blg
hank/paper/*.out
hank/paper/*.toc
hank/paper/main.tex.bak
hank/paper/mainNotes.bib       # revtex auto-generated

# Large clifford_t data directories (experimental outputs; > 1 GB total)
hank/clifford_t/norm_data/
hank/clifford_t/diag_data/
hank/clifford_t/full_sets/
hank/clifford_t/group+extension/
hank/clifford_t/extensions/
hank/clifford_t/testdata/
hank/clifford_t/test_data/
hank/clifford_t/groups/

# qco sweep outputs (thousands of small per-run .txt files — regenerable from
# the pipeline). If you want to preserve a specific snapshot, commit a
# tarball under hank/snapshots/ instead.
hank/qco-main/data_*/
hank/qco-main_opt/data_*/
hank/qco-main/qt_results*.txt
hank/qco-main_opt/qt_results*.txt
hank/qco-main/qcoG*.txt
hank/qco-main_opt/qcoG*.txt

# Paper-source tarball extraction (has own source in literature/*.tar.gz)
hank/literature/paper_extracted/

# Small zipped artefact of an earlier qco-main_opt snapshot
hank/files.zip

# Editor / OS
.DS_Store
*.swp
*~
.idea/
.vscode/

# Ad-hoc backups
*.bak
*.orig
